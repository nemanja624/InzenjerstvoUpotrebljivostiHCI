<Window x:Class="Mercedes_Models_CMS.Pages.AddCarModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mercedes_Models_CMS.Pages"
               xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
                xmlns:fa5="http://schemas.fontawesome.com/icons/"
            xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"


        mc:Ignorable="d"
        Title="AddCarModel" Height="750" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseDown"
        Background="Transparent">
    <Border CornerRadius="25"
        Background="{StaticResource PrimaryBlackBrush}"
        BorderBrush="{StaticResource AccentGoldBrush}"
        BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                <TextBlock Text=" ADD NEW CAR MODEL" Style="{StaticResource TitleText}" 
           HorizontalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="1" Margin="5">
                <Label  Foreground="{StaticResource AccentGoldBrush}" Content="Model name:"/>
                <TextBox x:Name="ModelName_TextBox" Style="{StaticResource InputTextBox}"/>
                <Label x:Name="ModelName_Error_Label" Foreground="Red"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="5" Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                <Label  Foreground="{StaticResource AccentGoldBrush}" Content="Horse power:"/>
                    <fa5:FontAwesome Icon="Solid_Horse" Foreground="{StaticResource AccentGoldBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBox x:Name="HorsePower_TextBox" Style="{StaticResource InputTextBox}"/>
                <Label x:Name="HorsePower_Error_Label" Foreground="Red"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="5 10 5 5" Grid.Column="0">
                <Border BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="1.5">
                        <Canvas HorizontalAlignment="Center"  Width="335" Height="198" Background="WhiteSmoke">
                        <Image x:Name="ModelImage" Width="335" Height="198"/>
                    </Canvas>
                </Border>
                <Button
                    x:Name="Browse_Button"
                    Grid.Row="10"
                    Width="150"
                    Height="46"
                    Padding="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    FontSize="15"
                    FontWeight="ExtraBold"
                    MouseEnter="Browse_Button_MouseEnter"
                    MouseLeave="Browse_Button_MouseLeave" Click="Browse_Button_Click">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            FontWeight="ExtraBold"
                            Text="Browse" />
                        <fa5:SvgAwesome
                                Height="25"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource AccentGoldBrush}"
                                Icon="Regular_Images"
                            x:Name="Fa5Image"/>
                    </StackPanel>
                </Button>
                <Label Foreground="Red" x:Name="Image_Error_Label"/>
            </StackPanel>
            <DockPanel
                Grid.Row="3"
                Grid.ColumnSpan="2"
                Margin="5,5,5,5">
                <ToolBar x:Name="EditorToolBar"
                         BorderBrush="{StaticResource AccentGoldBrush}"
                        BorderThickness="1"
                         DockPanel.Dock="Top" Background="{StaticResource AccentGoldBrush}">
                    <ToggleButton
                        x:Name="BoldToggleButton"
                        Width="30"
                        Height="30"
                        Command="EditingCommands.ToggleBold"
                        FontWeight="Bold"
                        ToolTip="Bold"
                        BorderBrush="{StaticResource AccentGoldBrush}"
                        BorderThickness="1">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                        <fa5:SvgAwesome
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Black"
                            Icon="Solid_Bold" />    
                    </ToggleButton>
                    <Separator />
                    <ToggleButton
                            x:Name="ItalicButton"
                            Width="30"
                            Height="30"
                            Command="EditingCommands.ToggleItalic"
                            FontStyle="Italic"
                            ToolTip="Italic"
                            BorderBrush="{StaticResource AccentGoldBrush}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                        <fa5:SvgAwesome
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Black"
                            Icon="Solid_Italic" />
                    </ToggleButton>
                    <Separator />
                    <ToggleButton
                        x:Name="UnderlineButton"
                        Width="30"
                        Height="30"
                        Command="EditingCommands.ToggleUnderline"
                        ToolTip="Underline"
                        BorderBrush="{StaticResource AccentGoldBrush}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                        <fa5:SvgAwesome
                Height="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="Black"
                            Icon="Solid_Underline" />
                    </ToggleButton>
                    <Separator />
                    <ComboBox
                        Name="FontFamilyComboBox"
                        Width="200"
                        IsEditable="False"
                        IsTextSearchCaseSensitive="False"
                        IsTextSearchEnabled="True"
                        SelectionChanged="FontFamilyComboBox_SelectionChanged"
                        BorderBrush="{StaticResource AccentGoldBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                     MaxWidth="200"
                                     FontFamily="{Binding Source}"
                                     Text="{Binding Source}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Separator />
                    <ComboBox
                        x:Name="FontSizeComboBox"
                        Width="50"
                        IsTextSearchCaseSensitive="False"
                        IsTextSearchEnabled="True"
                        SelectionChanged="FontSizeComboBox_SelectionChanged"
                        ToolTip="Font size"
                        BorderBrush="{StaticResource AccentGoldBrush}">
                        <ComboBoxItem Content="8" />
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="12" />
                        <ComboBoxItem Content="14" />
                        <ComboBoxItem Content="16" />
                        <ComboBoxItem Content="18" />
                        <ComboBoxItem Content="20" />
                        <ComboBoxItem Content="22" />
                    </ComboBox>
                    <Separator />
                    <xctk:ColorPicker
                        Name="ColorPickerText"
                        Width="100"
                        DisplayColorAndName="True"
                        SelectedColorChanged="ColorPickerText_SelectedColorChanged"
                        BorderBrush="{StaticResource AccentGoldBrush}"
                        Background="{StaticResource AccentGoldBrush}"/>
                </ToolBar>
                <RichTextBox
                        x:Name="EditorRichTextBox"
                        FontFamily="Courier New"
                        KeyUp="EditorRichTextBox_KeyUp"
                        SelectionChanged="EditorRichTextBox_SelectionChanged"
                        VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
            <StackPanel Grid.Row="4" Grid.Column="0">
                <Label x:Name="RichTextBox_Error_Label" Foreground="Red"/>
                <Label x:Name="Words_Label" Content="Words:" Foreground="{StaticResource AccentGoldBrush}"/>
                <Button x:Name="Add_Button" Content="ADD" Click="Add_Button_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="1" VerticalAlignment="Bottom">
                <Button x:Name="Cancel_Button" Content="CANCEL" Click="Cancel_Button_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
